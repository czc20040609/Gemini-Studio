{
  "name": "gemini-studio",
  "version": "1.0.0",
  "description": "Gemini Studio 桌面客户端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gemini.studio",
    "productName": "Gemini Studio",
    "win": {
      "target": "nsis",
      "icon": "assents/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}